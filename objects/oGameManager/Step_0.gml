// --- POWER-UP COOLDOWN TICK DOWN ---
if (global.powerup_cooldown > 0) 
{
    global.powerup_cooldown--;
}

// --- FREEZE TIMER TICK DOWN ---
if (global.freeze_timer > 0) 
{
    global.freeze_timer--;
}

// --- SPEED BOOST TIMER TICK DOWN ---
if (global.speed_timer > 0) 
{
    global.speed_timer--;
}